# TailorVision .gitignore

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so
*.dylib
.Python
env/
venv/
.venv/
.venv_311/
pip-wheel-metadata/

# ── Model files (large binary files — must be downloaded manually) ────────────
data/smplx/*.pkl
models/smplx/*.npz
models/smplx/smplx/*.npz

# ── Third-party repos (cloned separately) ────────────────────────────────────
third_party/SMPL-Anthropometry/

# ── Output / debug artifacts ──────────────────────────────────────────────────
*.obj
front_pose.jpg
side_pose.jpg
result.json
data/smpl/smpl_body_parts_2_faces.json
data/smplx/smplx_body_parts_2_faces.json

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
